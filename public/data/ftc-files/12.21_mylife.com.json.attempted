{
  "case_info": {
    "docket_number": "2:20-cv-6692",
    "company": {
      "name": "MyLife.com, Inc.",
      "incorporation_state": "Delaware",
      "entity_type": "corporation",
      "address": "1100 Glendon Ave, Suite 720, Los Angeles, California 90024",
      "business_description": "MyLife sells consumer background reports through its website. Since approximately 2009, the company has allowed users to run free background searches for individuals and has sold premium subscriptions that display search results implying criminal or sexual offense records, as well as a 'Reputation Score' based on public information and personal reviews."
    },
    "commissioners": [],
